# ==================== CRITICAL: DATABASE CONFIGURATION ====================
# REQUIRED: Must be set before deployment. Never use default values in production.
NEO4J_URI=bolt://your-neo4j-host:7687
NEO4J_USER=your_neo4j_username
NEO4J_PASSWORD=your_strong_password_here

# ==================== CRITICAL: API KEYS ====================
# REQUIRED: Must be set before deployment. Keep these secret!
SARVAM_API_KEY=your_sarvam_api_key_here

# ==================== SECURITY CONFIGURATION ====================
# CORS: Comma-separated list of allowed origins (no wildcards in production!)
# Examples: http://localhost:3000,https://myapp.com
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Allow credentials in CORS requests (use sparingly)
CORS_ALLOW_CREDENTIALS=false

# ==================== RATE LIMITING ====================
# Requests per window (requests allowed in the time window below)
RATE_LIMIT_REQUESTS=100

# Time window in seconds
RATE_LIMIT_WINDOW_SECONDS=60

# ==================== AUDIO PROCESSING ====================
# Maximum audio file size in MB
MAX_AUDIO_FILE_SIZE_MB=10

# Sarvam AI API endpoint
SARVAM_AUDIO_API_URL=https://api.sarvam.ai/speech-to-text

# ==================== BACKGROUND AGENT (PSA) ====================
# Polling interval for Perpetual State Agent in seconds
PSA_POLLING_INTERVAL_SECONDS=30

# Time threshold (in minutes) before marking requests as STALE
PSA_STALE_THRESHOLD_MINUTES=5

# Enable/disable PSA background agent
PSA_ENABLED=true

# ==================== DATABASE CONNECTION POOL ====================
# Size of Neo4j connection pool (tune based on expected load)
NEO4J_CONNECTION_POOL_SIZE=50

# ==================== LOGGING ====================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
